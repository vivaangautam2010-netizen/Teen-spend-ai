/* ---------------- AI advice (detailed habit-improvement plan) ----------------
   Builds on the same classifier/benchmark data used in Results, but goes
   deeper: it ranks specific categories worth working on, gives concrete
   category-level tips, lays out a 4-week plan, and projects the dollar
   impact of following it. Still rule-based, same spirit as classifyRisk. */
const CATEGORY_TIPS = {
  food: "Set a weekly grocery/food-delivery budget instead of spending as you go, and batch-prepare a few meals to cut delivery orders.",
  transport: "Check if a weekly or monthly transit pass beats what you're paying per ride — recurring passes are almost always cheaper.",
  entertainment: "Give yourself a fixed weekly entertainment cap, and mix in a few free options (library events, free streaming trials you already have) most weeks.",
  shopping: "Use a 24-hour rule before any non-essential purchase over $20, and unsubscribe from retailer emails that trigger impulse buys.",
  tech: "Audit every subscription and app purchase this month — cancel anything you haven't used in the last 30 days.",
  personal: "Buy personal care items during sales in slightly larger quantities instead of restocking one at a time at full price.",
  health: "Compare pharmacy or provider prices, and check whether a student health plan already covers something you're paying out of pocket for.",
  other: "Track everything landing in 'Other' for two weeks before cutting it — you can't fix a category you can't see clearly yet."
};

function buildPriorities(latest){
  const income = latest.income, categories = latest.categories, totalSpending = latest.totalSpending;
  const items = CATS.map(c => {
    const amt = categories[c.key];
    const currentPct = income > 0 ? (amt/income)*100 : 0;
    const benchPct = BENCHMARK_PCT_INCOME[c.key];
    const diff = currentPct - benchPct;
    const shareOfSpend = totalSpending > 0 ? (amt/totalSpending)*100 : 0;
    return {key:c.key, label:c.label, amt, currentPct, benchPct, diff, shareOfSpend};
  });
  const overspend = items.filter(i => i.diff > 2).sort((a,b) => b.diff - a.diff);
  let priorities = overspend.slice(0,3);
  if(priorities.length < 3){
    const remaining = items.filter(i => !priorities.includes(i)).sort((a,b) => b.shareOfSpend - a.shareOfSpend);
    priorities = priorities.concat(remaining.slice(0, 3 - priorities.length));
  }
  return priorities;
}

function generateAdvice(latest){
  const income = latest.income;
  const savingsRate = income > 0 ? (latest.savings/income)*100 : 0;
  const priorities = buildPriorities(latest).map(p => {
    const isOver = p.diff > 0;
    const suggestedAmt = isOver ? income * (p.benchPct/100) : p.amt;
    const rawCut = Math.max(0, p.amt - suggestedAmt);
    const cut = Math.min(rawCut, p.amt * 0.5); // keep suggestions realistic
    const newAmt = p.amt - cut;
    let rationale;
    if(isOver && cut > 1){
      rationale = `You're spending ${fmt(p.amt)}/mo here (${Math.round(p.currentPct)}% of income), versus ${Math.round(p.benchPct)}% for the average student. ${CATEGORY_TIPS[p.key]} Trimming toward ${fmt(Math.round(newAmt))}/mo would free up about ${fmt(Math.round(cut))} a month.`;
    } else {
      rationale = `You're already at or below the student average here (${Math.round(p.currentPct)}% vs ${Math.round(p.benchPct)}% of income). ${CATEGORY_TIPS[p.key]}`;
    }
    return {...p, isOver, cut, newAmt, rationale};
  });

  const topCat = priorities[0];
  const monthlyDelta = priorities.reduce((sum,p) => sum + (p.isOver ? p.cut : 0), 0);
  const annualDelta = monthlyDelta * 12;
  const newSavingsRate = income > 0 ? ((latest.savings + monthlyDelta)/income) * 100 : savingsRate;

  const narrative = `Your latest analysis puts you at ${latest.risk}, with a savings rate of ${Math.round(savingsRate)}% and ${topCat.label.toLowerCase()} as the area with the most room to improve. `
    + (topCat.isOver
        ? `You're currently putting ${Math.round(topCat.currentPct)}% of your income into ${topCat.label.toLowerCase()}, noticeably above the ${Math.round(topCat.benchPct)}% average across our student benchmark sample. `
        : `Your spending is fairly close to the student benchmark across most categories, so the plan below focuses on tightening habits rather than a single problem area. `)
    + `The plan below breaks the next four weeks into small, specific steps rather than one big change.`;

  return {narrative, priorities, monthlyDelta, annualDelta, newSavingsRate, savingsRate, topCat};
}

function renderAdvice(){
  const latest = getLatestAnalysis();
  const empty = document.getElementById('advice-empty');
  const content = document.getElementById('advice-content');
  if(!latest){ empty.style.display = 'block'; content.style.display = 'none'; return; }
  empty.style.display = 'none';
  content.style.display = 'block';

  const advice = generateAdvice(latest);
  document.getElementById('advice-narrative').textContent = advice.narrative;

  const priorEl = document.getElementById('advice-priorities');
