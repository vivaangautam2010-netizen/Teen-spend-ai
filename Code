<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SpendSense AI — Understand your spending</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<style>
  :root{
    --navy-950:#070b16;
    --navy-900:#0c1224;
    --navy-800:#131c33;
    --navy-700:#1c2842;
    --line:#263254;
    --ink:#f4f7fb;
    --ink-dim:#9aa6c4;
    --ink-faint:#5f6b8c;
    --pulse:#2fe6ad;
    --pulse-dim:#1a8f6d;
    --amber:#f5b942;
    --coral:#ff6b6b;
    --radius:16px;
    --display: 'Space Grotesk', sans-serif;
    --body: 'Inter', sans-serif;
    --mono: 'IBM Plex Mono', monospace;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:var(--navy-950);
    color:var(--ink);
    font-family:var(--body);
    line-height:1.5;
    -webkit-font-smoothing:antialiased;
  }
  h1,h2,h3,h4{font-family:var(--display); margin:0; letter-spacing:-0.01em;}
  p{margin:0;}
  a{color:inherit;}
  button{font-family:var(--body); cursor:pointer;}
  ::selection{background:var(--pulse); color:var(--navy-950);}

  .screen{display:none; min-height:100vh;}
  .screen.active{display:block;}

  /* ---------- NAV ---------- */
  .nav{
    position:sticky; top:0; z-index:50;
    display:flex; align-items:center; justify-content:space-between;
    padding:18px 32px;
    background:rgba(7,11,22,0.85);
    backdrop-filter:blur(10px);
    border-bottom:1px solid var(--line);
  }
  .nav-logo{display:flex; align-items:center; gap:10px; font-family:var(--display); font-weight:700; font-size:19px;}
  .nav-logo .dot-pulse{width:10px;height:10px;border-radius:50%;background:var(--pulse); box-shadow:0 0 10px var(--pulse);}
  .nav-links{display:flex; align-items:center; gap:8px;}
  .nav-links button{font-size:14px;}
  .navbtn{
    background:transparent; border:1px solid transparent; color:var(--ink-dim);
    padding:9px 16px; border-radius:10px; font-weight:500; transition:.15s;
  }
  .navbtn:hover{color:var(--ink); border-color:var(--line);}
  .navbtn.primary{background:var(--pulse); color:var(--navy-950); font-weight:600;}
  .navbtn.primary:hover{background:#3ffcc0;}
  .nav-user{display:flex; align-items:center; gap:10px; font-size:14px; color:var(--ink-dim);}
  .avatar{width:30px;height:30px;border-radius:50%;background:var(--navy-700); border:1px solid var(--line); display:flex; align-items:center; justify-content:center; font-family:var(--mono); font-size:12px; color:var(--pulse);}

  .wrap{max-width:1120px; margin:0 auto; padding:0 32px;}

  /* ---------- LANDING ---------- */
  .hero{
    padding:96px 32px 80px; text-align:center; position:relative; overflow:hidden;
  }
  .hero-pulse{max-width:760px; margin:0 auto 36px; height:90px;}
  .hero h1{font-size:clamp(40px,6vw,72px); font-weight:700; line-height:1.02;}
  .hero .accent{color:var(--pulse);}
  .hero p.sub{max-width:560px; margin:22px auto 0; color:var(--ink-dim); font-size:18px;}
  .cta-row{display:flex; gap:14px; justify-content:center; margin-top:36px; flex-wrap:wrap;}
  .btn{
    padding:14px 26px; border-radius:12px; border:1px solid var(--line);
    background:var(--navy-800); color:var(--ink); font-weight:600; font-size:15px; transition:.15s;
  }
  .btn.primary{background:var(--pulse); color:var(--navy-950); border-color:var(--pulse);}
  .btn.primary:hover{background:#3ffcc0; transform:translateY(-1px);}
  .btn:hover{border-color:var(--pulse-dim);}

  .section{padding:72px 32px; border-top:1px solid var(--line);}
  .section .eyebrow{color:var(--pulse); font-family:var(--mono); font-size:13px; letter-spacing:.08em; text-transform:uppercase;}
  .section h2{font-size:32px; margin-top:10px; max-width:600px;}
  .grid3{display:grid; grid-template-columns:repeat(3,1fr); gap:20px; margin-top:40px;}
  .grid2{display:grid; grid-template-columns:1.1fr 0.9fr; gap:48px; align-items:center; margin-top:40px;}
  @media(max-width:860px){.grid3{grid-template-columns:1fr;} .grid2{grid-template-columns:1fr;}}
  .card{
    background:var(--navy-800); border:1px solid var(--line); border-radius:var(--radius); padding:26px;
  }
  .card h3{font-size:17px; margin-bottom:8px;}
  .card p{color:var(--ink-dim); font-size:14px;}
  .num-tag{font-family:var(--mono); color:var(--ink-faint); font-size:13px; margin-bottom:14px; display:block;}

  .footer-cta{text-align:center; padding:90px 32px; border-top:1px solid var(--line);}
  .footer-cta h2{font-size:34px; margin-bottom:20px;}
  .foot{padding:28px 32px; text-align:center; color:var(--ink-faint); font-size:13px; border-top:1px solid var(--line);}

  /* ---------- AUTH ---------- */
  .auth-shell{
    min-height:100vh; display:flex; align-items:center; justify-content:center; padding:32px;
  }
  .auth-card{
    width:100%; max-width:420px; background:var(--navy-800); border:1px solid var(--line);
    border-radius:20px; padding:40px;
  }
  .auth-card h2{font-size:26px; margin-bottom:6px;}
  .auth-card p.hint{color:var(--ink-dim); font-size:14px; margin-bottom:28px;}
  .field{margin-bottom:16px;}
  .field label{display:block; font-size:13px; color:var(--ink-dim); margin-bottom:6px; font-weight:500;}
  .field input, .field select{
    width:100%; padding:12px 14px; border-radius:10px; border:1px solid var(--line);
    background:var(--navy-900); color:var(--ink); font-size:14px; font-family:var(--body);
  }
  .field input:focus, .field select:focus, .field textarea:focus{outline:2px solid var(--pulse); outline-offset:1px;}
  .auth-submit{width:100%; margin-top:8px; padding:13px; border-radius:10px; border:none; background:var(--pulse); color:var(--navy-950); font-weight:700; font-size:15px;}
  .auth-submit:hover{background:#3ffcc0;}
  .auth-switch{margin-top:20px; text-align:center; font-size:14px; color:var(--ink-dim);}
  .auth-switch button{background:none; border:none; color:var(--pulse); font-weight:600; padding:0;}
  .auth-error{background:rgba(255,107,107,0.1); border:1px solid var(--coral); color:#ffb2b2; padding:10px 14px; border-radius:10px; font-size:13px; margin-bottom:16px; display:none;}

  /* ---------- APP SHELL ---------- */
  .app-body{padding:40px 32px 80px;}
  .app-head{display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:28px; flex-wrap:wrap; gap:16px;}
  .app-head h1{font-size:28px;}
  .app-head p{color:var(--ink-dim); font-size:14px; margin-top:4px;}
  .tab-row{display:flex; gap:8px; margin-bottom:32px; flex-wrap:wrap;}
  .tab{padding:9px 16px; border-radius:10px; border:1px solid var(--line); background:transparent; color:var(--ink-dim); font-size:14px; font-weight:500;}
  .tab.active{background:var(--navy-800); color:var(--pulse); border-color:var(--pulse-dim);}

  .stat-grid{display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:24px;}
  @media(max-width:900px){.stat-grid{grid-template-columns:repeat(2,1fr);}}
  .stat-card{background:var(--navy-800); border:1px solid var(--line); border-radius:14px; padding:20px;}
  .stat-card .label{color:var(--ink-faint); font-size:12px; text-transform:uppercase; letter-spacing:.06em; font-family:var(--mono);}
  .stat-card .value{font-family:var(--mono); font-size:26px; margin-top:8px; font-weight:500;}
  .stat-card .value.green{color:var(--pulse);}
  .stat-card .value.amber{color:var(--amber);}
  .stat-card .value.coral{color:var(--coral);}

  .panel-grid{display:grid; grid-template-columns:1.3fr 1fr; gap:20px;}
  @media(max-width:900px){.panel-grid{grid-template-columns:1fr;}}
  .panel{background:var(--navy-800); border:1px solid var(--line); border-radius:16px; padding:24px;}
  .panel h3{font-size:16px; margin-bottom:16px;}
  .empty-state{text-align:center; padding:40px 20px; color:var(--ink-dim);}
  .empty-state .btn{margin-top:16px;}

  .risk-badge{display:inline-flex; align-items:center; gap:8px; padding:7px 14px; border-radius:999px; font-size:13px; font-weight:600; font-family:var(--mono);}
  .risk-badge.low{background:rgba(47,230,173,0.12); color:var(--pulse);}
  .risk-badge.balanced{background:rgba(245,185,66,0.12); color:var(--amber);}
  .risk-badge.high{background:rgba(255,107,107,0.12); color:var(--coral);}
  .risk-badge .dot{width:7px;height:7px;border-radius:50%;background:currentColor;}

  /* ---------- FORM ---------- */
  .form-shell{max-width:760px; margin:0 auto;}
  .form-section{margin-bottom:28px;}
  .form-section h4{font-size:14px; text-transform:uppercase; letter-spacing:.06em; color:var(--ink-faint); font-family:var(--mono); margin-bottom:14px;}
  .cat-grid{display:grid; grid-template-columns:repeat(2,1fr); gap:14px;}
  @media(max-width:640px){.cat-grid{grid-template-columns:1fr;}}
  .cat-field{background:var(--navy-800); border:1px solid var(--line); border-radius:12px; padding:14px 16px;}
  .cat-field label{display:flex; align-items:center; gap:8px; font-size:13px; color:var(--ink-dim); margin-bottom:8px;}
  .cat-field input{width:100%; background:transparent; border:none; color:var(--ink); font-family:var(--mono); font-size:20px; padding:0;}
  .cat-field input:focus{outline:none;}
  .cat-icon{width:8px;height:8px;border-radius:50%;}

  /* ---------- RESULTS ---------- */
  .result-hero{
    background:linear-gradient(135deg, var(--navy-800), var(--navy-900));
    border:1px solid var(--line); border-radius:20px; padding:36px; margin-bottom:24px;
    display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:20px;
  }
  .result-hero .waveform{width:220px; height:60px;}
  .insight-list, .rec-list{list-style:none; margin:0; padding:0;}
  .insight-list li, .rec-list li{
    padding:14px 0; border-bottom:1px solid var(--line); display:flex; gap:12px; font-size:14px; color:var(--ink-dim);
  }
  .insight-list li:last-child, .rec-list li:last-child{border-bottom:none;}
  .insight-list li::before{content:"◆"; color:var(--pulse); font-size:10px; margin-top:4px;}
  .rec-list li{counter-increment:rec;}
  .rec-list{counter-reset:rec;}
  .rec-list li::before{content:counter(rec); font-family:var(--mono); color:var(--navy-950); background:var(--pulse); width:20px; height:20px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:11px; flex-shrink:0;}

  /* ---------- CHATBOT ---------- */
  .chat-shell{max-width:680px; margin:0 auto; background:var(--navy-800); border:1px solid var(--line); border-radius:18px; display:flex; flex-direction:column; height:560px;}
  .chat-log{flex:1; overflow-y:auto; padding:24px; display:flex; flex-direction:column; gap:14px;}
  .msg{max-width:78%; padding:12px 16px; border-radius:14px; font-size:14px; line-height:1.5;}
  .msg.bot{background:var(--navy-700); align-self:flex-start; border-bottom-left-radius:4px;}
  .msg.user{background:var(--pulse); color:var(--navy-950); align-self:flex-end; border-bottom-right-radius:4px; font-weight:500;}
  .chat-suggest{display:flex; gap:8px; padding:0 24px 14px; flex-wrap:wrap;}
  .chip{background:var(--navy-900); border:1px solid var(--line); color:var(--ink-dim); font-size:12px; padding:7px 12px; border-radius:999px;}
  .chip:hover{border-color:var(--pulse-dim); color:var(--ink);}
  .chat-input-row{display:flex; gap:10px; padding:16px; border-top:1px solid var(--line);}
  .chat-input-row input{flex:1; background:var(--navy-900); border:1px solid var(--line); border-radius:10px; padding:12px 14px; color:var(--ink); font-size:14px;}
  .chat-input-row input:focus{outline:2px solid var(--pulse); outline-offset:1px;}
  .chat-input-row button{background:var(--pulse); border:none; color:var(--navy-950); border-radius:10px; padding:0 20px; font-weight:700;}

  /* ---------- PROGRESS ---------- */
  .history-row{display:flex; justify-content:space-between; align-items:center; padding:16px 0; border-bottom:1px solid var(--line); font-size:14px;}
  .history-row:last-child{border-bottom:none;}
  .history-row .date{color:var(--ink-faint); font-family:var(--mono); font-size:12px;}

  canvas{max-width:100%;}
  .sr-only{position:absolute; width:1px;height:1px; overflow:hidden; clip:rect(0,0,0,0);}
  @media (prefers-reduced-motion: reduce){ *{animation:none !important; transition:none !important;} }
</style>
</head>
<body>

<!-- ============ LANDING ============ -->
<div class="screen active" id="screen-landing">
  <nav class="nav">
    <div class="nav-logo"><span class="dot-pulse"></span>SpendSense AI</div>
    <div class="nav-links" id="landing-nav-links">
      <button class="navbtn" onclick="go('login')">Log in</button>
      <button class="navbtn primary" onclick="go('signup')">Sign up</button>
    </div>
  </nav>

  <section class="hero">
    <svg class="hero-pulse" viewBox="0 0 760 90" fill="none" xmlns="http://www.w3.org/2000/svg">
      <polyline points="0,45 90,45 115,15 140,75 165,45 300,45 320,25 340,65 360,45 500,45 525,10 550,80 575,45 760,45"
        stroke="#2fe6ad" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round" fill="none" opacity="0.9"/>
    </svg>
    <h1>Understand your <span class="accent">spending</span>.<br>Build smarter money habits.</h1>
    <p class="sub">SpendSense AI reads your spending like a pulse — steady, balanced, or racing — and turns it into plain-language guidance built for teens.</p>
    <div class="cta-row">
      <button class="btn primary" onclick="go('signup')">Start Your Spending Analysis</button>
      <button class="btn" onclick="go('login')">I already have an account</button>
    </div>
  </section>

  <section class="section">
    <span class="eyebrow">The problem</span>
    <h2>Most teens have never seen their own spending pattern — just their bank balance.</h2>
    <div class="grid3">
      <div class="card"><span class="num-tag">// no visibility</span><h3>Spending feels invisible</h3><p>Money moves across food, apps, clothes and rides with nothing tying it together into a pattern you can actually see.</p></div>
      <div class="card"><span class="num-tag">// no context</span><h3>No sense of "normal"</h3><p>Without a baseline, it's hard to know if $40 a week on food delivery is fine or a warning sign.</p></div>
      <div class="card"><span class="num-tag">// no feedback loop</span><h3>Habits don't self-correct</h3><p>Behaviour only changes when someone gets a clear signal and a next step — not just a number.</p></div>
    </div>
  </section>

  <section class="section">
    <div class="grid2">
      <div>
        <span class="eyebrow">How the AI helps</span>
        <h2>SpendSense AI turns eight spending categories into one clear read on your behaviour.</h2>
        <p style="color:var(--ink-dim); margin-top:16px; font-size:15px;">You enter what you earn and what you spend. The engine classifies your behaviour as Low Spending Risk, Balanced, or High Spending Risk, then explains exactly which categories are driving that result — in your own numbers, not generic advice.</p>
      </div>
      <div class="card" style="padding:32px;">
        <svg viewBox="0 0 300 100" width="100%" height="100">
          <polyline points="0,60 40,60 55,30 70,80 85,60 150,60 165,40 180,70 195,60 260,60 275,20 290,85 300,60" stroke="#2fe6ad" stroke-width="2" fill="none"/>
        </svg>
        <p style="text-align:center; color:var(--ink-faint); font-family:var(--mono); font-size:12px; margin-top:8px;">a calm pulse = balanced spending</p>
      </div>
    </div>
  </section>

  <section class="section">
    <span class="eyebrow">Features</span>
    <h2>Everything you need to see the pattern and change it.</h2>
    <div class="grid3">
      <div class="card"><span class="num-tag">01</span><h3>Spending analysis</h3><p>Break down income and spending across 8 categories with an instant behaviour classification.</p></div>
      <div class="card"><span class="num-tag">02</span><h3>AI insights &amp; recommendations</h3><p>Plain-language observations about where money is going, with specific next steps to try this week.</p></div>
      <div class="card"><span class="num-tag">03</span><h3>Financial assistant chat</h3><p>Ask questions about your own results and get answers grounded in your actual numbers.</p></div>
      <div class="card"><span class="num-tag">04</span><h3>Progress tracking</h3><p>Re-run your analysis over time and watch your risk category and savings rate move.</p></div>
      <div class="card"><span class="num-tag">05</span><h3>Private by design</h3><p>Every account only ever sees its own data — nothing is shared across users.</p></div>
      <div class="card"><span class="num-tag">06</span><h3>Built to grow</h3><p>The classifier is structured so a trained machine-learning model can be swapped in later.</p></div>
    </div>
  </section>

  <section class="footer-cta">
    <h2>Ready to see your spending pulse?</h2>
    <button class="btn primary" onclick="go('signup')">Start Your Spending Analysis</button>
  </section>

  <div class="foot">SpendSense AI — a prototype financial behaviour assistant. Not a real bank or financial institution.</div>
</div>

<!-- ============ SIGNUP ============ -->
<div class="screen" id="screen-signup">
  <div class="auth-shell">
    <div class="auth-card">
      <h2>Create your account</h2>
      <p class="hint">Takes about a minute. Your data stays on your account only.</p>
      <div class="auth-error" id="signup-error">Something's missing — check the fields below.</div>
      <form id="signup-form" onsubmit="return handleSignup(event)">
        <div class="field"><label for="su-name">Full name</label><input id="su-name" type="text" required></div>
        <div class="field"><label for="su-email">Email</label><input id="su-email" type="email" required></div>
        <div class="field"><label for="su-password">Password</label><input id="su-password" type="password" minlength="4" required></div>
        <div class="field">
          <label for="su-age">Age group</label>
          <select id="su-age" required>
            <option value="">Select one</option>
            <option>13–15</option>
            <option>16–17</option>
            <option>18–19</option>
          </select>
        </div>
        <button class="auth-submit" type="submit">Create account</button>
      </form>
      <div class="auth-switch">Already have an account? <button onclick="go('login')">Log in</button></div>
      <div class="auth-switch"><button onclick="go('landing')">← Back to home</button></div>
    </div>
  </div>
</div>

<!-- ============ LOGIN ============ -->
<div class="screen" id="screen-login">
  <div class="auth-shell">
    <div class="auth-card">
      <h2>Welcome back</h2>
      <p class="hint">Log in to see your spending analysis.</p>
      <div class="auth-error" id="login-error">We couldn't find an account with those details.</div>
      <form id="login-form" onsubmit="return handleLogin(event)">
        <div class="field"><label for="li-email">Email</label><input id="li-email" type="email" required></div>
        <div class="field"><label for="li-password">Password</label><input id="li-password" type="password" required></div>
        <button class="auth-submit" type="submit">Log in</button>
      </form>
      <div class="auth-switch">New here? <button onclick="go('signup')">Create an account</button></div>
      <div class="auth-switch"><button onclick="go('landing')">← Back to home</button></div>
    </div>
  </div>
</div>

<!-- ============ APP (authenticated) ============ -->
<div class="screen" id="screen-app">
  <nav class="nav">
    <div class="nav-logo"><span class="dot-pulse"></span>SpendSense AI</div>
    <div class="nav-user">
      <span id="nav-username-display"></span>
      <div class="avatar" id="nav-avatar">?</div>
      <button class="navbtn" onclick="handleLogout()">Log out</button>
    </div>
  </nav>

  <div class="app-body wrap">
    <div class="tab-row">
      <button class="tab" data-tab="dashboard" onclick="showTab('dashboard')">Dashboard</button>
      <button class="tab" data-tab="form" onclick="showTab('form')">Spending Analysis</button>
      <button class="tab" data-tab="results" onclick="showTab('results')">Results</button>
      <button class="tab" data-tab="chatbot" onclick="showTab('chatbot')">AI Assistant</button>
      <button class="tab" data-tab="progress" onclick="showTab('progress')">Progress</button>
      <button class="tab" data-tab="profile" onclick="showTab('profile')">Profile</button>
    </div>

    <!-- DASHBOARD -->
    <div class="tab-panel" id="tab-dashboard">
      <div class="app-head">
        <div><h1 id="dash-greeting">Welcome back</h1><p>Here's your financial overview.</p></div>
      </div>
      <div id="dash-empty" class="empty-state" style="display:none;">
        <h3>No analysis yet</h3>
        <p>Run your first spending analysis to unlock your dashboard.</p>
        <button class="btn primary" onclick="showTab('form')">Analyze My Spending</button>
      </div>
      <div id="dash-content">
        <div class="stat-grid">
          <div class="stat-card"><div class="label">Monthly income</div><div class="value" id="stat-income">—</div></div>
          <div class="stat-card"><div class="label">Total spending</div><div class="value" id="stat-spending">—</div></div>
          <div class="stat-card"><div class="label">Savings</div><div class="value green" id="stat-savings">—</div></div>
          <div class="stat-card"><div class="label">Behaviour</div><div class="value" id="stat-risk">—</div></div>
        </div>
        <div class="panel-grid">
          <div class="panel">
            <h3>Spending by category</h3>
            <canvas id="chart-category" height="220"></canvas>
          </div>
          <div class="panel">
            <h3>Quick actions</h3>
            <p style="color:var(--ink-dim); font-size:14px; margin-bottom:16px;">Keep your analysis current to track real progress.</p>
            <button class="btn primary" style="width:100%; margin-bottom:10px;" onclick="showTab('form')">Run a new analysis</button>
            <button class="btn" style="width:100%; margin-bottom:10px;" onclick="showTab('chatbot')">Ask the AI assistant</button>
            <button class="btn" style="width:100%;" onclick="showTab('progress')">View progress</button>
          </div>
        </div>
      </div>
