<script>
/* ================================================================
   SpendSense AI — front-end prototype
   ------------------------------------------------------------
   Everything below runs entirely in the browser. There is no real
   server or database: `db` simulates one in memory for this
   session so the whole product can be demoed end to end. Wire this
   up to a real backend (auth service + database) and swap
   classifyRisk() for a trained model to take this to production.
   ================================================================ */

const db = {
  users: [],           // {name, email, password, ageGroup}
  analysesByEmail: {}  // email -> [{date, age, income, categories:{}, savings, totalSpending, risk, insights, recs}]
};

let currentUser = null;   // email of logged-in user
let charts = {};          // Chart.js instances, keyed by canvas id

const CATS = [
  {key:'food', label:'Food', color:'#2fe6ad'},
  {key:'transport', label:'Transportation', color:'#4fc3f7'},
  {key:'entertainment', label:'Entertainment', color:'#f5b942'},
  {key:'shopping', label:'Shopping', color:'#ff6b6b'},
  {key:'tech', label:'Technology', color:'#b18cff'},
  {key:'personal', label:'Personal care', color:'#ff9de2'},
  {key:'health', label:'Health', color:'#7de8c8'},
  {key:'other', label:'Other', color:'#9aa6c4'}
];

/* Benchmark data, derived from an uploaded sample of 1,000 college
   students' real monthly spending. Values are each category's
   average share of monthly income across the sample. The dataset
   has no direct "shopping" category, so books/supplies spend is
   used as the closest available proxy. Used only for descriptive
   peer comparison — it does not drive the risk classifier. */
const BENCHMARK_PCT_INCOME = {
  food: 24.8, transport: 12.2, entertainment: 8.3, shopping: 17.1,
  tech: 17.5, personal: 5.9, health: 11.2, other: 10.7
};
const BENCHMARK_SAMPLE_SIZE = 1000;

/* Reference numbers derived from a 32,424-record synthetic personal
   finance dataset (adults, not teens — used for general financial
   education/context in the chatbot, not for peer category comparison).
   Note: in that dataset, credit_score had ~0 correlation with expense
   ratio, debt-to-income, or savings-to-income — i.e. no learnable
   predictive relationship existed between them. Rather than fit a
   model to noise, these are honest percentile snapshots used to give
   the chatbot real-world reference points. */
const FINANCE_REF = {
  sampleSize: 32424,
  expenseRatio: {p25: 0.45, median: 0.60, p75: 0.75},   // monthly expenses / monthly income
  monthsSaved: {p25: 2.6, median: 5.0, p75: 7.5},         // savings / monthly income, in "months"
  pctNoLoan: 60,                                          // % of people with no active loan
  creditScore: {p25: 437, median: 575, p75: 714}          // FICO-style 300–850 scale, for education only
};

/* ---------------- navigation ---------------- */
function go(screenId){
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screen-' + screenId).classList.add('active');
  window.scrollTo(0,0);
}

/* ---------------- theme toggle (visual only — no effect on any app data/logic) ---------------- */
function toggleTheme(){
  const html = document.documentElement;
  if(html.getAttribute('data-theme') === 'light'){
    html.removeAttribute('data-theme'); // back to dark, the default
  } else {
    html.setAttribute('data-theme', 'light');
  }
}

function showTab(tab){
  document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.tab === tab));
  document.querySelectorAll('.tab-panel').forEach(p => p.style.display = 'none');
  document.getElementById('tab-' + tab).style.display = 'block';
  if(tab === 'dashboard') renderDashboard();
  if(tab === 'form') updateSavingsPreview();
  if(tab === 'results') renderResults();
  if(tab === 'advice') renderAdvice();
  if(tab === 'progress') renderProgress();
  if(tab === 'chatbot' && document.getElementById('chat-answer').dataset.inited !== 'true'){ document.getElementById('chat-answer').dataset.inited = 'true'; initChat(); }
  if(tab === 'profile') renderProfile();
}

/* ---------------- auth ---------------- */
function handleSignup(e){
  e.preventDefault();
  const name = document.getElementById('su-name').value.trim();
  const email = document.getElementById('su-email').value.trim().toLowerCase();
  const password = document.getElementById('su-password').value;
  const ageGroup = document.getElementById('su-age').value;
  const err = document.getElementById('signup-error');

  if(db.users.some(u => u.email === email)){
    err.textContent = "An account with that email already exists.";
    err.style.display = 'block';
    return false;
  }
  db.users.push({name, email, password, ageGroup});
  db.analysesByEmail[email] = [];
  err.style.display = 'none';
  loginAs(email);
  return false;
}

function handleLogin(e){
  e.preventDefault();
  const email = document.getElementById('li-email').value.trim().toLowerCase();
  const password = document.getElementById('li-password').value;
  const err = document.getElementById('login-error');
  const user = db.users.find(u => u.email === email && u.password === password);
  if(!user){
    err.style.display = 'block';
    return false;
  }
  err.style.display = 'none';
  loginAs(email);
  return false;
}

function loginAs(email){
  currentUser = email;
  const user = db.users.find(u => u.email === email);
  document.getElementById('nav-username-display').textContent = user.name;
  document.getElementById('nav-avatar').textContent = user.name.charAt(0).toUpperCase();
  go('app');
  showTab('dashboard');
}

function handleLogout(){
  currentUser = null;
  destroyAllCharts();
  go('landing');
}

/* ---------------- quick access code ----------------
   Deliberately simple: a single fixed 6-digit code checked in
   client-side JS. Entering it just logs into a normal account (no
   email/password needed) — it does NOT unlock any special admin
   view or extra controls, it's purely a shortcut past the login
   form. That's fine for a prototype/demo; it is NOT real access
   control, since anyone can read the code straight out of the page
   source, and everyone who uses it lands in the same shared account. */
const ADMIN_CODE = '191210';
const ADMIN_SHORTCUT_EMAIL = 'quickaccess@spendsense.ai';

function ensureAdminShortcutUser(){
  if(!db.users.find(u => u.email === ADMIN_SHORTCUT_EMAIL)){
    db.users.push({name: 'Boss', email: ADMIN_SHORTCUT_EMAIL, password: '', ageGroup: '16–17'});
    db.analysesByEmail[ADMIN_SHORTCUT_EMAIL] = [];
  }
}

function handleAdminLogin(e){
  e.preventDefault();
  const code = document.getElementById('admin-code').value.trim();
  const err = document.getElementById('admin-error');
  if(code !== ADMIN_CODE){
    err.style.display = 'block';
    return false;
  }
  err.style.display = 'none';
  document.getElementById('admin-login-form').reset();
  ensureAdminShortcutUser();
  loginAs(ADMIN_SHORTCUT_EMAIL); // same landing spot as a normal login — dashboard, no special controls
  return false;
}

/* ---------------- helpers: current user's data ---------------- */
function getUser(){ return db.users.find(u => u.email === currentUser); }
function getAnalyses(){ return db.analysesByEmail[currentUser] || []; }
function getLatestAnalysis(){ const a = getAnalyses(); return a.length ? a[a.length-1] : null; }
function fmt(n){ return '$' + Number(n).toLocaleString(undefined, {maximumFractionDigits:0}); }

/* ---------------- AI classification engine ----------------
   Rule-based prototype classifier. Structured so the same inputs
   (category spend, income, savings) could later be fed to a
   trained clustering / classification model instead of these
   hand-written thresholds. */
function classifyRisk(income, totalSpending, savings, categories){
  const spendingRatio = income > 0 ? totalSpending / income : 1;
  const savingsRate = income > 0 ? savings / income : 0;
  const maxCat = Object.entries(categories).sort((a,b)=>b[1]-a[1])[0];
  const concentration = totalSpending > 0 ? maxCat[1] / totalSpending : 0;

  let score = (savingsRate * 100) - (spendingRatio * 60) - (concentration > 0.4 ? 12 : 0);

  let risk;
  if(spendingRatio > 1) risk = 'High Spending Risk';
  else if(score >= 12) risk = 'Low Spending Risk';
  else if(score >= -8) risk = 'Balanced Spending';
  else risk = 'High Spending Risk';

  return {risk, spendingRatio, savingsRate, concentration, topCategory: maxCat[0]};
}

function catLabel(key){ return CATS.find(c => c.key === key).label; }

function generateInsights(categories, totalSpending, income, savings, meta){
  const insights = [];
  const sorted = Object.entries(categories).sort((a,b)=>b[1]-a[1]);
  const [topKey, topVal] = sorted[0];
  const topPct = totalSpending > 0 ? Math.round((topVal/totalSpending)*100) : 0;

  if(topPct >= 30){
    insights.push(`You spend a large share of your money on ${catLabel(topKey).toLowerCase()} — about ${topPct}% of your total spending.`);
  }
  if(meta.savingsRate < 0.1){
    insights.push(`Your savings rate is under 10% of your income, which leaves little cushion for unexpected costs.`);
  } else if(meta.savingsRate >= 0.2){
    insights.push(`You're saving ${Math.round(meta.savingsRate*100)}% of your income — a strong habit worth keeping.`);
  }
  const entertainmentShopping = (categories.entertainment + categories.shopping);
  if(totalSpending > 0 && entertainmentShopping/totalSpending > 0.35){
    insights.push(`Entertainment and shopping together make up over a third of your spending — often the first place impulse purchases show up.`);
  }
  if(meta.spendingRatio > 1){
    insights.push(`You're spending more than you bring in this month, which isn't sustainable without dipping into savings.`);
  }
  if(insights.length < 2){
    insights.push(`Your spending is distributed fairly evenly across categories, without one area dominating your budget.`);
  }

  // Benchmark comparison against the uploaded student spending sample
  if(income > 0){
    let biggestGapKey = null, biggestGapDiff = 0, biggestGapUserPct = 0;
    CATS.forEach(c => {
      const userPct = (categories[c.key] / income) * 100;
      const diff = userPct - BENCHMARK_PCT_INCOME[c.key];
      if(Math.abs(diff) > Math.abs(biggestGapDiff)){
        biggestGapDiff = diff; biggestGapKey = c.key; biggestGapUserPct = userPct;
      }
    });
    if(biggestGapKey && Math.abs(biggestGapDiff) >= 6){
      const direction = biggestGapDiff > 0 ? 'more' : 'less';
      insights.push(`Compared to the average student in our ${BENCHMARK_SAMPLE_SIZE.toLocaleString()}-person benchmark sample, you spend about ${Math.round(Math.abs(biggestGapDiff))} percentage points ${direction} of your income on ${catLabel(biggestGapKey).toLowerCase()} (${Math.round(biggestGapUserPct)}% vs. ${Math.round(BENCHMARK_PCT_INCOME[biggestGapKey])}% average).`);
    }
  }
  return insights;
}

function generateRecommendations(meta, categories){
  const recs = [];
  if(meta.savingsRate < 0.2){
    recs.push('Try saving 20% of your allowance before you spend on anything else.');
  }
  if(categories.entertainment > 0){
    recs.push('Set a weekly entertainment budget and track it against your actual spending.');
  }
  if(categories.shopping / (Object.values(categories).reduce((a,b)=>a+b,0) || 1) > 0.2){
    recs.push('Wait 24 hours before making non-essential purchases over $20.');
  }
  if(meta.spendingRatio > 0.9){
    recs.push('Review your largest category and look for one recurring cost you could cut this month.');
  }
  recs.push('Re-run your analysis next month to see how these changes shift your risk category.');
  return recs.slice(0,4);
}

/* ---------------- spending form ---------------- */
function handleAnalyze(e){
  e.preventDefault();
  const age = Number(document.getElementById('f-age').value);
  const income = Number(document.getElementById('f-income').value);
  const categories = {};
  CATS.forEach(c => categories[c.key] = Number(document.getElementById('f-' + c.key).value) || 0);
  const totalSpending = Object.values(categories).reduce((a,b)=>a+b,0);
  const savings = Math.max(0, income - totalSpending); // auto-calculated, not manually entered

  const meta = classifyRisk(income, totalSpending, savings, categories);
  const insights = generateInsights(categories, totalSpending, income, savings, meta);
  const recs = generateRecommendations(meta, categories);

  const analysis = {
    date: new Date().toISOString().slice(0,10),
    age, income, categories, savings, totalSpending,
    risk: meta.risk, insights, recs
  };
  getAnalyses().push(analysis);
  document.getElementById('spend-form').reset();
  updateSavingsPreview();
  showTab('results');
  return false;
}

function updateSavingsPreview(){
  const income = Number(document.getElementById('f-income').value) || 0;
  let totalSpending = 0;
  CATS.forEach(c => { totalSpending += Number(document.getElementById('f-' + c.key).value) || 0; });
  const savings = income - totalSpending;

  document.getElementById('sp-income').textContent = fmt(income);
  document.getElementById('sp-spending').textContent = fmt(totalSpending);
  const totalEl = document.getElementById('sp-savings').parentElement;
  const hint = document.getElementById('sp-hint');

  if(savings < 0){
    document.getElementById('sp-savings').textContent = fmt(0);
    totalEl.classList.add('deficit');
    hint.textContent = `You're on track to spend ${fmt(Math.abs(savings))} more than you bring in this month — savings shows as $0 rather than negative.`;
  } else {
    document.getElementById('sp-savings').textContent = fmt(savings);
    totalEl.classList.remove('deficit');
    hint.textContent = `This updates automatically as you fill in income and spending above — no need to enter it yourself.`;
  }
}

