<script>
/* ================================================================
   SpendSense AI — front-end prototype
   ------------------------------------------------------------
   Everything below runs entirely in the browser. There is no real
   server or database: `db` simulates one in memory for this
   session so the whole product can be demoed end to end. Wire this
   up to a real backend (auth service + database) and swap
   classifyRisk() for a trained model to take this to production.
   ================================================================ */

const db = {
  users: [],           // {name, email, password, ageGroup}
  analysesByEmail: {}  // email -> [{date, age, income, categories:{}, savings, totalSpending, risk, insights, recs}]
};

let currentUser = null;   // email of logged-in user
let charts = {};          // Chart.js instances, keyed by canvas id

const CATS = [
  {key:'food', label:'Food', color:'#2fe6ad'},
  {key:'transport', label:'Transportation', color:'#4fc3f7'},
  {key:'entertainment', label:'Entertainment', color:'#f5b942'},
  {key:'shopping', label:'Shopping', color:'#ff6b6b'},
  {key:'tech', label:'Technology', color:'#b18cff'},
  {key:'personal', label:'Personal care', color:'#ff9de2'},
  {key:'health', label:'Health', color:'#7de8c8'},
  {key:'other', label:'Other', color:'#9aa6c4'}
];

/* Benchmark data, derived from an uploaded sample of 1,000 college
   students' real monthly spending. Values are each category's
   average share of monthly income across the sample. The dataset
   has no direct "shopping" category, so books/supplies spend is
   used as the closest available proxy. Used only for descriptive
   peer comparison — it does not drive the risk classifier. */
const BENCHMARK_PCT_INCOME = {
  food: 24.8, transport: 12.2, entertainment: 8.3, shopping: 17.1,
  tech: 17.5, personal: 5.9, health: 11.2, other: 10.7
};
const BENCHMARK_SAMPLE_SIZE = 1000;

/* ---------------- navigation ---------------- */
function go(screenId){
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screen-' + screenId).classList.add('active');
  window.scrollTo(0,0);
}

function showTab(tab){
  document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.tab === tab));
  document.querySelectorAll('.tab-panel').forEach(p => p.style.display = 'none');
  document.getElementById('tab-' + tab).style.display = 'block';
  if(tab === 'dashboard') renderDashboard();
  if(tab === 'results') renderResults();
  if(tab === 'progress') renderProgress();
  if(tab === 'chatbot' && document.getElementById('chat-log').children.length === 0) initChat();
  if(tab === 'profile') renderProfile();
}

/* ---------------- auth ---------------- */
function handleSignup(e){
  e.preventDefault();
  const name = document.getElementById('su-name').value.trim();
  const email = document.getElementById('su-email').value.trim().toLowerCase();
  const password = document.getElementById('su-password').value;
  const ageGroup = document.getElementById('su-age').value;
  const err = document.getElementById('signup-error');

  if(db.users.some(u => u.email === email)){
    err.textContent = "An account with that email already exists.";
    err.style.display = 'block';
    return false;
  }
  db.users.push({name, email, password, ageGroup});
  db.analysesByEmail[email] = [];
  err.style.display = 'none';
  loginAs(email);
  return false;
}

function handleLogin(e){
  e.preventDefault();
  const email = document.getElementById('li-email').value.trim().toLowerCase();
  const password = document.getElementById('li-password').value;
  const err = document.getElementById('login-error');
  const user = db.users.find(u => u.email === email && u.password === password);
  if(!user){
    err.style.display = 'block';
    return false;
  }
  err.style.display = 'none';
  loginAs(email);
  return false;
}

function loginAs(email){
  currentUser = email;
  const user = db.users.find(u => u.email === email);
  document.getElementById('nav-username-display').textContent = user.name;
  document.getElementById('nav-avatar').textContent = user.name.charAt(0).toUpperCase();
  go('app');
  showTab('dashboard');
}

function handleLogout(){
  currentUser = null;
  destroyAllCharts();
  go('landing');
}

/* ---------------- helpers: current user's data ---------------- */
function getUser(){ return db.users.find(u => u.email === currentUser); }
function getAnalyses(){ return db.analysesByEmail[currentUser] || []; }
function getLatestAnalysis(){ const a = getAnalyses(); return a.length ? a[a.length-1] : null; }
function fmt(n){ return '$' + Number(n).toLocaleString(undefined, {maximumFractionDigits:0}); }

/* ---------------- AI classification engine ----------------
   Rule-based prototype classifier. Structured so the same inputs
   (category spend, income, savings) could later be fed to a
   trained clustering / classification model instead of these
   hand-written thresholds. */
function classifyRisk(income, totalSpending, savings, categories){
  const spendingRatio = income > 0 ? totalSpending / income : 1;
  const savingsRate = income > 0 ? savings / income : 0;
  const maxCat = Object.entries(categories).sort((a,b)=>b[1]-a[1])[0];
  const concentration = totalSpending > 0 ? maxCat[1] / totalSpending : 0;

  let score = (savingsRate * 100) - (spendingRatio * 60) - (concentration > 0.4 ? 12 : 0);

  let risk;
  if(spendingRatio > 1) risk = 'High Spending Risk';
  else if(score >= 12) risk = 'Low Spending Risk';
  else if(score >= -8) risk = 'Balanced Spending';
  else risk = 'High Spending Risk';

  return {risk, spendingRatio, savingsRate, concentration, topCategory: maxCat[0]};
}

function catLabel(key){ return CATS.find(c => c.key === key).label; }

function generateInsights(categories, totalSpending, income, savings, meta){
  const insights = [];
  const sorted = Object.entries(categories).sort((a,b)=>b[1]-a[1]);
  const [topKey, topVal] = sorted[0];
  const topPct = totalSpending > 0 ? Math.round((topVal/totalSpending)*100) : 0;

  if(topPct >= 30){
    insights.push(`You spend a large share of your money on ${catLabel(topKey).toLowerCase()} — about ${topPct}% of your total spending.`);
  }
  if(meta.savingsRate < 0.1){
    insights.push(`Your savings rate is under 10% of your income, which leaves little cushion for unexpected costs.`);
  } else if(meta.savingsRate >= 0.2){
    insights.push(`You're saving ${Math.round(meta.savingsRate*100)}% of your income — a strong habit worth keeping.`);
  }
  const entertainmentShopping = (categories.entertainment + categories.shopping);
  if(totalSpending > 0 && entertainmentShopping/totalSpending > 0.35){
    insights.push(`Entertainment and shopping together make up over a third of your spending — often the first place impulse purchases show up.`);
  }
  if(meta.spendingRatio > 1){
    insights.push(`You're spending more than you bring in this month, which isn't sustainable without dipping into savings.`);
  }
  if(insights.length < 2){
    insights.push(`Your spending is distributed fairly evenly across categories, without one area dominating your budget.`);
  }

  // Benchmark comparison against the uploaded student spending sample
  if(income > 0){
    let biggestGapKey = null, biggestGapDiff = 0, biggestGapUserPct = 0;
    CATS.forEach(c => {
      const userPct = (categories[c.key] / income) * 100;
      const diff = userPct - BENCHMARK_PCT_INCOME[c.key];
      if(Math.abs(diff) > Math.abs(biggestGapDiff)){
        biggestGapDiff = diff; biggestGapKey = c.key; biggestGapUserPct = userPct;
      }
    });
    if(biggestGapKey && Math.abs(biggestGapDiff) >= 6){
      const direction = biggestGapDiff > 0 ? 'more' : 'less';
      insights.push(`Compared to the average student in our ${BENCHMARK_SAMPLE_SIZE.toLocaleString()}-person benchmark sample, you spend about ${Math.round(Math.abs(biggestGapDiff))} percentage points ${direction} of your income on ${catLabel(biggestGapKey).toLowerCase()} (${Math.round(biggestGapUserPct)}% vs. ${Math.round(BENCHMARK_PCT_INCOME[biggestGapKey])}% average).`);
    }
  }
  return insights;
}

function generateRecommendations(meta, categories){
  const recs = [];
  if(meta.savingsRate < 0.2){
    recs.push('Try saving 20% of your allowance before you spend on anything else.');
  }
  if(categories.entertainment > 0){
    recs.push('Set a weekly entertainment budget and track it against your actual spending.');
  }
  if(categories.shopping / (Object.values(categories).reduce((a,b)=>a+b,0) || 1) > 0.2){
    recs.push('Wait 24 hours before making non-essential purchases over $20.');
  }
  if(meta.spendingRatio > 0.9){
    recs.push('Review your largest category and look for one recurring cost you could cut this month.');
  }
  recs.push('Re-run your analysis next month to see how these changes shift your risk category.');
  return recs.slice(0,4);
}

/* ---------------- spending form ---------------- */
function handleAnalyze(e){
  e.preventDefault();
  const age = Number(document.getElementById('f-age').value);
  const income = Number(document.getElementById('f-income').value);
  const categories = {};
  CATS.forEach(c => categories[c.key] = Number(document.getElementById('f-' + c.key).value) || 0);
  const savings = Number(document.getElementById('f-savings').value);
  const totalSpending = Object.values(categories).reduce((a,b)=>a+b,0);

  const meta = classifyRisk(income, totalSpending, savings, categories);
  const insights = generateInsights(categories, totalSpending, income, savings, meta);
  const recs = generateRecommendations(meta, categories);

  const analysis = {
    date: new Date().toISOString().slice(0,10),
    age, income, categories, savings, totalSpending,
    risk: meta.risk, insights, recs
  };
  getAnalyses().push(analysis);
  document.getElementById('spend-form').reset();
  showTab('results');
  return false;
}

/* ---------------- dashboard ---------------- */
function renderDashboard(){
  const user = getUser();
  document.getElementById('dash-greeting').textContent = `Welcome back, ${user.name.split(' ')[0]}`;
  const latest = getLatestAnalysis();
  const empty = document.getElementById('dash-empty');
  const content = document.getElementById('dash-content');
  if(!latest){
    empty.style.display = 'block';
    content.style.display = 'none';
    return;
  }
  empty.style.display = 'none';
  content.style.display = 'block';

  document.getElementById('stat-income').textContent = fmt(latest.income);
  document.getElementById('stat-spending').textContent = fmt(latest.totalSpending);
  document.getElementById('stat-savings').textContent = fmt(latest.savings);
  const riskEl = document.getElementById('stat-risk');
  riskEl.textContent = latest.risk.replace(' Spending Risk','').replace('Balanced Spending','Balanced');
  riskEl.className = 'value ' + riskColorClass(latest.risk);

  renderCategoryChart('chart-category', latest.categories);
}

function riskColorClass(risk){
  if(risk === 'Low Spending Risk') return 'green';
  if(risk === 'Balanced Spending') return 'amber';
  return 'coral';
}

function renderCategoryChart(canvasId, categories){
  const ctx = document.getElementById(canvasId).getContext('2d');
  destroyChart(canvasId);
  charts[canvasId] = new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: CATS.map(c => c.label),
      datasets: [{
        data: CATS.map(c => categories[c.key]),
        backgroundColor: CATS.map(c => c.color),
        borderColor: '#131c33',
        borderWidth: 2
      }]
    },
    options: {
      plugins: { legend: { position: 'bottom', labels: { color: '#9aa6c4', font: { family: 'Inter', size: 11 }, padding: 12 } } },
      cutout: '62%'
    }
  });
}

/* ---------------- results ---------------- */
function renderResults(){
  const latest = getLatestAnalysis();
  const empty = document.getElementById('results-empty');
  const content = document.getElementById('results-content');
  if(!latest){ empty.style.display = 'block'; content.style.display = 'none'; return; }
  empty.style.display = 'none';
  content.style.display = 'block';

  const badge = document.getElementById('result-badge');
  const badgeClass = latest.risk === 'Low Spending Risk' ? 'low' : (latest.risk === 'Balanced Spending' ? 'balanced' : 'high');
  badge.className = 'risk-badge ' + badgeClass;
  document.getElementById('result-badge-text').textContent = latest.risk;
  document.getElementById('result-risk-word').textContent = latest.risk.replace(' Spending Risk','').replace('Balanced Spending','Balanced');

  drawWaveform('result-waveform', badgeClass);

  const insightList = document.getElementById('insight-list');
  insightList.innerHTML = '';
  latest.insights.forEach(i => { const li = document.createElement('li'); li.textContent = i; insightList.appendChild(li); });

  const recList = document.getElementById('rec-list');
  recList.innerHTML = '';
  latest.recs.forEach(r => { const li = document.createElement('li'); li.textContent = r; recList.appendChild(li); });

  renderCategoryChart('chart-results-cat', latest.categories);
  renderBenchmarkChart(latest.categories, latest.income);
}

function renderBenchmarkChart(categories, income){
  const ctx = document.getElementById('chart-benchmark').getContext('2d');
  destroyChart('chart-benchmark');
  const userPct = CATS.map(c => income > 0 ? Math.round((categories[c.key] / income) * 1000) / 10 : 0);
  const benchPct = CATS.map(c => BENCHMARK_PCT_INCOME[c.key]);
  charts['chart-benchmark'] = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: CATS.map(c => c.label),
      datasets: [
        { label: 'You', data: userPct, backgroundColor: '#2fe6ad', borderRadius: 4 },
        { label: 'Average student', data: benchPct, backgroundColor: '#3c4a6e', borderRadius: 4 }
      ]
    },
    options: {
      plugins: { legend: { labels: { color: '#9aa6c4', font:{family:'Inter', size:11} } } },
      scales: {
        x: { ticks: { color: '#9aa6c4', font:{family:'Inter', size:11} }, grid: { display:false } },
        y: { ticks: { color: '#5f6b8c', font:{family:'IBM Plex Mono', size:10}, callback:v=>v+'%' }, grid: { color:'#1c2842' }, title:{display:true, text:'% of income', color:'#5f6b8c', font:{family:'Inter', size:11}} }
      }
    }
  });
}

function drawWaveform(svgId, riskClass){
  const svg = document.getElementById(svgId);
  const color = riskClass === 'low' ? '#2fe6ad' : (riskClass === 'balanced' ? '#f5b942' : '#ff6b6b');
  let points;
  if(riskClass === 'low'){
    points = "0,30 40,30 55,22 70,38 85,30 130,30 145,24 160,36 175,30 220,30";
  } else if(riskClass === 'balanced'){
    points = "0,30 35,30 50,12 65,48 80,30 125,30 140,15 155,45 170,30 220,30";
  } else {
    points = "0,30 25,30 35,5 45,55 55,30 90,30 100,8 110,52 120,30 150,30 160,3 170,57 180,30 220,30";
  }
  svg.innerHTML = `<polyline points="${points}" stroke="${color}" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round" fill="none"/>`;
}

/* ---------------- chatbot ---------------- */
function initChat(){
  const log = document.getElementById('chat-log');
  const user = getUser();
  const latest = getLatestAnalysis();
  const greeting = latest
    ? `Hi ${user.name.split(' ')[0]}, I can see your latest analysis shows ${latest.risk}. Ask me anything about it.`
    : `Hi ${user.name.split(' ')[0]}, run a spending analysis first and I'll be able to answer questions about your specific numbers. In the meantime, ask me anything general.`;
  addChatMessage(greeting, 'bot');
}

function addChatMessage(text, who){
  const log = document.getElementById('chat-log');
  const div = document.createElement('div');
  div.className = 'msg ' + who;
  div.textContent = text;
  log.appendChild(div);
  log.scrollTop = log.scrollHeight;
}

function sendSuggested(text){
  document.getElementById('chat-input').value = text;
  handleChatSubmit(new Event('submit'));
}

function handleChatSubmit(e){
  if(e && e.preventDefault) e.preventDefault();
  const input = document.getElementById('chat-input');
  const text = input.value.trim();
  if(!text) return false;
  addChatMessage(text, 'user');
  input.value = '';
  setTimeout(() => addChatMessage(generateChatReply(text), 'bot'), 350);
  return false;
}

function generateChatReply(question){
  const q = question.toLowerCase();
  const latest = getLatestAnalysis();

  if(!latest){
    return "I don't have a spending analysis for you yet — head to the Spending Analysis tab and fill it in, then come back and ask me again.";
  }

  const topCat = Object.entries(latest.categories).sort((a,b)=>b[1]-a[1])[0];
  const savingsRate = latest.income > 0 ? Math.round((latest.savings/latest.income)*100) : 0;

  if(q.includes('save') && !q.includes('why')){
    return `You're currently saving ${savingsRate}% of your income. A simple next step: move ${Math.max(10, 20-savingsRate)}% more of your allowance into savings before you spend on anything else, and set a weekly cap on ${catLabel(topCat[0]).toLowerCase()}, your biggest category right now.`;
  }
  if(q.includes('why') && (q.includes('high') || q.includes('risk'))){
    if(latest.risk === 'High Spending Risk'){
      return `Your risk is high mainly because ${catLabel(topCat[0]).toLowerCase()} takes up a large share of your spending and your savings rate (${savingsRate}%) is on the lower side relative to your income. Bringing that one category down usually moves the needle the most.`;
    }
    return `Good news — your current result is "${latest.risk}", not High Spending Risk. Your savings rate is ${savingsRate}% and spending looks reasonably balanced across categories.`;
  }
  if(q.includes('impulse')){
    return `Impulse purchases usually show up in entertainment and shopping. Try a 24-hour rule before buying anything over $20, and set a weekly budget for those two categories specifically.`;
  }
  if(q.includes('budget')){
    return `Based on your income of ${fmt(latest.income)}, a simple split to try: 50% needs, 30% wants, 20% savings. Right now your ${catLabel(topCat[0]).toLowerCase()} spending alone is ${fmt(topCat[1])}.`;
  }
  if(q.includes('savings rate') || q.includes('how much')){
    return `You saved ${fmt(latest.savings)} out of ${fmt(latest.income)} this month — that's a ${savingsRate}% savings rate.`;
  }
  if(q.includes('compare') || q.includes('average') || q.includes('other student') || q.includes('normal')){
    let biggestGapKey = null, biggestGapDiff = 0;
    CATS.forEach(c => {
      const userPct = latest.income > 0 ? (latest.categories[c.key] / latest.income) * 100 : 0;
      const diff = userPct - BENCHMARK_PCT_INCOME[c.key];
      if(Math.abs(diff) > Math.abs(biggestGapDiff)){ biggestGapDiff = diff; biggestGapKey = c.key; }
    });
    const direction = biggestGapDiff > 0 ? 'more' : 'less';
    return `Against our benchmark sample of ${BENCHMARK_SAMPLE_SIZE.toLocaleString()} students, your biggest difference is ${catLabel(biggestGapKey).toLowerCase()} — you spend about ${Math.round(Math.abs(biggestGapDiff))} percentage points ${direction} of your income there than average. You can see the full breakdown on the Results tab.`;
  }
  return `Based on your latest analysis (${latest.risk}, ${savingsRate}% savings rate), the biggest lever you have is your ${catLabel(topCat[0]).toLowerCase()} spending. Ask me how to save more, why your risk is what it is, or how to control impulse purchases.`;
}

/* ---------------- progress ---------------- */
function renderProgress(){
  const analyses = getAnalyses();
  const empty = document.getElementById('progress-empty');
  const content = document.getElementById('progress-content');
  if(analyses.length === 0){ empty.style.display = 'block'; content.style.display = 'none'; return; }
  empty.style.display = 'none';
  content.style.display = 'block';

  const ctx = document.getElementById('chart-progress').getContext('2d');
  destroyChart('chart-progress');
  charts['chart-progress'] = new Chart(ctx, {
    type: 'line',
    data: {
      labels: analyses.map((a,i) => `#${i+1} · ${a.date}`),
      datasets: [
        { label: 'Total spending', data: analyses.map(a => a.totalSpending), borderColor: '#ff6b6b', backgroundColor: 'transparent', tension:.3 },
        { label: 'Savings', data: analyses.map(a => a.savings), borderColor: '#2fe6ad', backgroundColor: 'transparent', tension:.3 }
      ]
    },
    options: {
      plugins: { legend: { labels: { color: '#9aa6c4', font:{family:'Inter'} } } },
      scales: {
        x: { ticks: { color: '#5f6b8c', font:{family:'IBM Plex Mono', size:10} }, grid: { color:'#1c2842' } },
        y: { ticks: { color: '#5f6b8c', font:{family:'IBM Plex Mono', size:10} }, grid: { color:'#1c2842' } }
      }
    }
  });

  const rows = document.getElementById('history-rows');
  rows.innerHTML = '';
  analyses.slice().reverse().forEach((a, idx) => {
    const badgeClass = a.risk === 'Low Spending Risk' ? 'low' : (a.risk === 'Balanced Spending' ? 'balanced' : 'high');
    const row = document.createElement('div');
    row.className = 'history-row';
    row.innerHTML = `
      <div><div>Analysis #${analyses.length - idx}</div><div class="date">${a.date}</div></div>
      <div style="font-family:var(--mono); font-size:13px;">${fmt(a.totalSpending)} spent · ${fmt(a.savings)} saved</div>
      <div class="risk-badge ${badgeClass}"><span class="dot"></span>${a.risk}</div>
    `;
    rows.appendChild(row);
  });
}

/* ---------------- profile ---------------- */
function renderProfile(){
  const user = getUser();
  document.getElementById('pf-name').value = user.name;
  document.getElementById('pf-email').value = user.email;
  document.getElementById('pf-age').value = user.ageGroup;
  document.getElementById('profile-saved').style.display = 'none';
}

function handleProfileSave(e){
  e.preventDefault();
  const user = getUser();
  user.name = document.getElementById('pf-name').value.trim();
  user.ageGroup = document.getElementById('pf-age').value;
  document.getElementById('nav-username-display').textContent = user.name;
  document.getElementById('nav-avatar').textContent = user.name.charAt(0).toUpperCase();
  document.getElementById('profile-saved').style.display = 'block';
  return false;
}

/* ---------------- chart lifecycle ---------------- */
function destroyChart(id){ if(charts[id]){ charts[id].destroy(); delete charts[id]; } }
function destroyAllCharts(){ Object.keys(charts).forEach(destroyChart); }
</script>
