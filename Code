function destroyChart(id){ if(charts[id]){ charts[id].destroy(); delete charts[id]; } }
function destroyAllCharts(){ Object.keys(charts).forEach(destroyChart); }

/* ---------------- mini spending calculator (floating widget) ----------------
   A standard 4-function calculator plus a running "session tally" so users
   can add up receipts/purchases as they go and see a total — separate from
   the full categorized Spending Analysis form, this is just a quick scratchpad. */
let calcState = { display: '0', prevValue: null, operator: null, waitingForOperand: false };
let tally = [];

function calcRender(){
  document.getElementById('calc-display').textContent = calcState.display;
}

function calcDigit(d){
  if(calcState.waitingForOperand){
    calcState.display = d;
    calcState.waitingForOperand = false;
  } else {
    calcState.display = calcState.display === '0' ? d : calcState.display + d;
  }
  calcRender();
}

function calcDecimal(){
  if(calcState.waitingForOperand){
    calcState.display = '0.';
    calcState.waitingForOperand = false;
  } else if(!calcState.display.includes('.')){
    calcState.display += '.';
  }
  calcRender();
}

function calcClear(){
  calcState = { display: '0', prevValue: null, operator: null, waitingForOperand: false };
  calcRender();
}

function calcBackspace(){
  if(calcState.waitingForOperand) return;
  calcState.display = calcState.display.length > 1 ? calcState.display.slice(0, -1) : '0';
  calcRender();
}

function calcToggleSign(){
  const val = parseFloat(calcState.display);
  calcState.display = String(val === 0 ? 0 : -val);
  calcRender();
}

function calcCompute(a, b, op){
  switch(op){
    case '+': return a + b;
    case '−': return a - b;
    case '×': return a * b;
    case '÷': return b === 0 ? 0 : a / b;
    default: return b;
  }
}

function calcRound(n){
  return Math.round(n * 100) / 100;
}

function calcOperator(nextOp){
  const inputValue = parseFloat(calcState.display);
  if(calcState.prevValue == null){
    calcState.prevValue = inputValue;
  } else if(calcState.operator && !calcState.waitingForOperand){
    calcState.prevValue = calcRound(calcCompute(calcState.prevValue, inputValue, calcState.operator));
    calcState.display = String(calcState.prevValue);
  }
  calcState.operator = nextOp;
  calcState.waitingForOperand = true;
  calcRender();
}

function calcEquals(){
  if(calcState.operator != null && calcState.prevValue != null){
    const inputValue = parseFloat(calcState.display);
    const result = calcRound(calcCompute(calcState.prevValue, inputValue, calcState.operator));
    calcState.display = String(result);
    calcState.prevValue = null;
    calcState.operator = null;
    calcState.waitingForOperand = true;
    calcRender();
  }
}

function addToTally(){
  const val = parseFloat(calcState.display);
  if(isNaN(val)) return;
  tally.push(val);
  renderTally();
}

function removeTallyItem(index){
  tally.splice(index, 1);
  renderTally();
}

function clearTally(){
  tally = [];
  renderTally();
}

function renderTally(){
  const list = document.getElementById('calc-tally-list');
  list.innerHTML = tally.map((v, i) =>
    `<div class="calc-tally-item"><span>${fmt(v)}</span><button onclick="removeTallyItem(${i})" title="Remove">✕</button></div>`
  ).join('');
  const total = tally.reduce((a, b) => a + b, 0);
  document.getElementById('calc-tally-total').textContent = fmt(total);
}
