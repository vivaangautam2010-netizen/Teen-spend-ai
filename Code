const CHAT_RELEVANT_KEYWORDS = [
  'save','sav','spend','budget','money','income','allowance','expense','cost','afford','price',
  'debt','loan','credit','interest','emergency fund','emergency','fund',
  'risk','categor','food','transport','entertainment','shop','tech','personal care','health','other expense',
  'compare','average','benchmark','normal','student',
  'progress','plan','advice','habit','goal','impulse','subscription','invest','financ','bank',
  'app','calculator','account','profile','password','privacy','data','delete','reset','tab','dashboard',
  'checking','compound','side hustle','job','earn','paycheck','tax','bill','rent','currency','wallet',
  'mortgage','retirement','401k','stock','crypto','bitcoin','inflation','scholarship','fafsa','insurance',
  'salary','wage','freelance','net worth','asset','liability','apr','refund','discount','coupon','deposit',
  'withdraw','transfer','fee','payment','purchase','wealth','poverty','economy','recession','market'
];

function isChatOnTopic(q){
  return CHAT_RELEVANT_KEYWORDS.some(k => q.includes(k));
}

function generateChatReply(question){
  const q = question.toLowerCase().trim();
  const latest = getLatestAnalysis();

  // Greetings / thanks — always fine regardless of analysis state
  if(/^(hi|hey|hello|yo|sup|good morning|good afternoon|good evening)\b/.test(q)){
    return latest
      ? `Hey! I've got your latest analysis loaded — ${latest.risk}, saving ${Math.round((latest.savings/latest.income)*100) || 0}% of your income. Ask me about your spending, savings, debt, credit, or how you stack up against real data.`
      : `Hey! Once you run a spending analysis I can dig into your actual numbers — for now, ask me anything about budgeting, saving, debt, or credit and I'll do my best.`;
  }
  if(/\b(thanks|thank you|thx|appreciate it)\b/.test(q)){
    return `Anytime! I'm here whenever you want to check in on your spending, savings, or general money questions.`;
  }

  // Off-topic guard
  if(!isChatOnTopic(q)){
    return `I can't answer this — it's irrelevant and not related to what I can help with here. In offline mode I can only cover finance and app-related questions (spending, saving, budgeting, debt, credit, investing, and similar); ask me something along those lines and I'll go into detail!`;
  }

  // --- App / feature questions (don't require a saved analysis) ---
  if(q.includes('calculator')){
    return `The quick calculator sits right next to the Spending Analysis form — it's a normal 4-function calculator plus a "session tally," so you can add up a stack of receipts or purchases and then type the running total into whichever category it belongs to, instead of doing the math in your head.`;
  }
  if(q.includes('what is this app') || q.includes('what does this app') || q.includes('how does this app') || (q.includes('app') && q.includes('do'))){
    return `SpendSense AI takes the numbers you enter — income, spending by category, and savings — and turns them into a plain-language read on your habits: a risk category (Low/Balanced/High), specific insights, a 4-week AI Advice plan, a comparison against real student spending data, and this chat for follow-up questions. Start on the Spending Analysis tab if you haven't already.`;
  }
  if(q.includes('privacy') || q.includes('is my data') || q.includes('delete') || q.includes('reset my') || q.includes('password')){
    return `Good question to ask. In this version, your account and analyses live only in this browser tab's memory for the current session — refreshing the page clears everything, and nothing is sent anywhere except this chat message itself. There's no way to "delete an account" because nothing persists beyond your session; closing the tab effectively resets it.`;
  }

  // --- General financial literacy (don't require a saved analysis either) ---
  if(q.includes('checking')){
    return `A checking account is for everyday spending — debit card purchases, paying bills, moving money in and out often, usually with little or no interest earned. A savings account is meant to hold money you're not touching often, and typically earns a bit of interest for leaving it alone. A common approach: paycheck/allowance lands in checking, then you automatically move a chunk to savings right away.`;
  }
  if(q.includes('compound')){
    return `Compound interest is interest earned on interest — money you save doesn't just grow by a flat amount each year, it grows on top of what it already grew. The earlier you start, the more time compounding has to work, which is why even small amounts saved as a teen can matter more than larger amounts saved later — time in the account matters more than the exact sum.`;
  }
  if(q.includes('retirement') || q.includes('401k')){
    return `Retirement accounts (like a 401(k) or IRA in the US) let money grow tax-advantaged over decades, and the earlier you start the more compounding works in your favor — someone who invests a small amount at 18 can end up ahead of someone who invests much more starting at 35, purely because of time. You likely can't open one until you have earned income and are old enough, but the savings habit you're building now is the exact skill that makes retirement saving work later.`;
  }
  if(q.includes('stock') || q.includes('crypto') || q.includes('bitcoin')){
    return `Stocks represent partial ownership in a company and can rise or fall in value based on how that company (and the market) performs; crypto is a different, higher-risk asset class with much larger price swings and less regulation. Both carry real risk of losing money, especially short-term, so they're generally not where you'd put money you need soon. If you're curious, learning the basics now is valuable — actually investing usually waits until you have a stable income and an emergency fund in place first.`;
  }
  if(q.includes('insurance')){
    return `Insurance is essentially paying a smaller, predictable amount regularly (a premium) to avoid a much larger, unpredictable cost later (an accident, illness, major loss). As a teen you're likely covered under a parent's health/auto insurance rather than buying your own — but it's a good concept to understand early, since almost every adult budget includes some form of it.`;
  }
  if(q.includes('mortgage')){
    return `A mortgage is a long-term loan used to buy property, typically paid back over 15–30 years with interest. It's one of the biggest financial commitments most people make, and lenders look closely at income, debt, and credit history before approving one — which loops right back to the habits this app tracks: keeping spending below income and building a solid credit history over time.`;
  }
  if(q.includes('invest')){
    return `Investing means putting money into something (like an index fund) with the expectation it grows over years, unlike a savings account's small guaranteed interest. It also carries real risk of losing value short-term, so it's generally for money you won't need soon. Many teens start with a custodial brokerage account a parent opens with them. It's a longer-term move than anything this app tracks month-to-month, but the saving habits you build here are exactly what funds it later.`;
  }
  if(q.includes('side hustle') || q.includes('earn more') || (q.includes('earn') && !q.includes('learn')) || q.includes('make money') || q.includes('paycheck')){
    return `Common realistic options at your stage: tutoring, babysitting/pet-sitting, freelance work if you have a skill (design, writing, video editing), a part-time retail/food service job once you're old enough, or reselling things you no longer use. Even an extra $50–100/month changes your numbers meaningfully — try adding it as income in your next analysis and see how your risk category shifts.`;
  }
  if(q.includes('tax')){
    return `As a teen with part-time or gig income, you may not owe much or anything in income tax depending on how much you earn and where you live, but it's worth keeping simple records of what you're paid. This app doesn't handle tax specifics — for anything beyond general awareness, a parent or a tax prep resource for your country/state is the right call.`;
  }

  if(!latest){
    // Still on-topic, but no analysis yet — answer what we can generally, using real reference data
    if(q.includes('emergency')){
      return `Great question to ask early! In a broad sample of ${FINANCE_REF.sampleSize.toLocaleString()} real personal-finance records, the median person had saved the equivalent of about ${FINANCE_REF.monthsSaved.median} months of income, and the top quarter had ${FINANCE_REF.monthsSaved.p75}+ months saved. That's a long-term target — a realistic starting goal is just one month of expenses tucked away where you won't be tempted to spend it. Run a spending analysis and I can help you figure out how much that would actually be for you.`;
    }
    if(q.includes('debt') || q.includes('loan') || q.includes('credit')){
      return `Good to be thinking about this before it's urgent. Credit scores typically run 300–850 and reflect how reliably someone pays back what they owe over time — you don't need any debt to start building good habits that matter later, like not spending more than you bring in. For reference, in a large sample of real financial records, about ${FINANCE_REF.pctNoLoan}% of people had no active loan at all, so being debt-free is common, not unusual. Run a spending analysis and I can tailor this to your situation.`;
    }
    return `I don't have a spending analysis for you yet, so I can only answer in general terms. Head to the Spending Analysis tab, fill it in, and come back — I'll be able to reference your actual numbers, not just averages.`;
  }

  const topCat = Object.entries(latest.categories).sort((a,b)=>b[1]-a[1])[0];
  const savingsRate = latest.income > 0 ? Math.round((latest.savings/latest.income)*100) : 0;
  const spendingRatio = latest.income > 0 ? latest.totalSpending / latest.income : 1;

  if(q.includes('sav') && !q.includes('why')){
    const target = Math.max(10, 20 - savingsRate);
    return `You're currently saving ${savingsRate}% of your income (${fmt(latest.savings)} out of ${fmt(latest.income)}). A solid next step: try moving ${target}% more into savings before you spend on anything else — even automating that transfer the moment you get paid makes it stick better than deciding manually each time. Meanwhile, ${catLabel(topCat[0]).toLowerCase()} is your biggest category (${fmt(topCat[1])}/mo) — a small weekly cap there would free up even more room to save. Want me to walk through a longer-term plan? Check the AI Advice tab for a full 4-week breakdown.`;
  }
  if(q.includes('why') && (q.includes('high') || q.includes('risk'))){
    if(latest.risk === 'High Spending Risk'){
      return `Your risk reads as High mainly for two reasons: ${catLabel(topCat[0]).toLowerCase()} is taking up a large share of your spending, and your savings rate (${savingsRate}%) is on the lower side relative to your income — you're spending about ${Math.round(spendingRatio*100)}% of what comes in. The fastest way to move the needle is usually the first one: even trimming ${catLabel(topCat[0]).toLowerCase()} by 10–15% for a month tends to shift the whole picture. Check the AI Advice tab — it lays out exactly how much to cut and where.`;
    }
    return `Good news — your current result is "${latest.risk}", not High Spending Risk. Your savings rate is ${savingsRate}%, and your spending is running at about ${Math.round(spendingRatio*100)}% of your income, which is fairly healthy. Keep an eye on ${catLabel(topCat[0]).toLowerCase()} since it's your largest category, but you're in reasonable shape.`;
  }
  if(q.includes('impulse')){
    return `Impulse purchases almost always show up in entertainment and shopping first — right now you're putting ${fmt(latest.categories.entertainment)}/mo into entertainment and ${fmt(latest.categories.shopping)}/mo into shopping. A 24-hour rule before buying anything over $20 catches most impulse spending, and setting a hard weekly cap on those two categories specifically (rather than a vague monthly goal) tends to work better because you get faster feedback on whether you're on track.`;
  }
  if(q.includes('budget')){
    return `Based on your income of ${fmt(latest.income)}, a simple split worth trying is 50% needs, 30% wants, 20% savings — that's roughly ${fmt(latest.income*0.5)}/${fmt(latest.income*0.3)}/${fmt(latest.income*0.2)}. Right now your biggest category is ${catLabel(topCat[0]).toLowerCase()} at ${fmt(topCat[1])}, and you're saving ${savingsRate}% of your income. If that split feels off for your situation, the AI Advice tab breaks it down category by category instead of just three buckets.`;
  }
  if(q.includes('compare') || q.includes('average') || q.includes('other student') || q.includes('normal') || q.includes('benchmark')){
    let biggestGapKey = null, biggestGapDiff = 0;
    CATS.forEach(c => {
      const userPct = latest.income > 0 ? (latest.categories[c.key] / latest.income) * 100 : 0;
      const diff = userPct - BENCHMARK_PCT_INCOME[c.key];
      if(Math.abs(diff) > Math.abs(biggestGapDiff)){ biggestGapDiff = diff; biggestGapKey = c.key; }
    });
    const direction = biggestGapDiff > 0 ? 'more' : 'less';
    return `Against our benchmark sample of ${BENCHMARK_SAMPLE_SIZE.toLocaleString()} students, your biggest difference is ${catLabel(biggestGapKey).toLowerCase()} — you spend about ${Math.round(Math.abs(biggestGapDiff))} percentage points ${direction} of your income there than average. Separately, in a much larger sample of ${FINANCE_REF.sampleSize.toLocaleString()} real adult financial records, the median person's total spending ran about ${Math.round(FINANCE_REF.expenseRatio.median*100)}% of their income — yours is at ${Math.round(spendingRatio*100)}%, for context. Full breakdown is on the Results tab.`;
  }
  if(q.includes('emergency')){
    const oneMonth = latest.totalSpending;
    return `Based on the median across ${FINANCE_REF.sampleSize.toLocaleString()} real financial records, people typically keep around ${FINANCE_REF.monthsSaved.median} months of income saved, with the top quarter at ${FINANCE_REF.monthsSaved.p75}+ months. That's a long-term goal, not a this-month one. For you right now, one month of expenses would be about ${fmt(oneMonth)} — a realistic first milestone before thinking bigger.`;
  }
  if(q.includes('debt') || q.includes('loan')){
    return `You haven't entered any debt info in SpendSense AI yet — this app tracks spending, not loans directly. For context though: in a sample of ${FINANCE_REF.sampleSize.toLocaleString()} real financial records, about ${FINANCE_REF.pctNoLoan}% of people had no active loan at all, so being debt-free (which most teens are) puts you in good company. The habits you're building now — spending less than you earn, saving consistently — are exactly what keeps future debt manageable if you do take some on later.`;
  }
  if(q.includes('credit')){
    return `Credit scores usually range 300–850 and reflect how reliably someone has repaid money they've borrowed over time — things like on-time payments and not maxing out available credit matter most. You likely don't have a credit history yet, and that's completely normal. The good news: consistent habits like keeping your spending below your income (you're at ${Math.round(spendingRatio*100)}% right now) and saving regularly are the same fundamentals that build a strong credit profile once you do start borrowing.`;
  }
  if(q.includes('subscription')){
    return `Subscriptions are sneaky because they don't feel like "spending" in the moment — they just renew. They usually hide inside your technology or entertainment categories. Worth doing: list every recurring charge you have right now, and cancel anything you haven't actually used in the last 30 days. Even $10–15/month in unused subscriptions adds up to over $100 a year.`;
  }
  if(q.includes('savings rate') || q.includes('how much')){
    return `You saved ${fmt(latest.savings)} out of ${fmt(latest.income)} this month — that's a ${savingsRate}% savings rate. Common guidance points to 20% as a strong target; you're ${savingsRate >= 20 ? 'already there, nice work' : `about ${20-savingsRate} points away from that`}.`;
  }

  return `Based on your latest analysis (${latest.risk}, ${savingsRate}% savings rate, spending at ${Math.round(spendingRatio*100)}% of income), the biggest lever you have is your ${catLabel(topCat[0]).toLowerCase()} spending. Ask me how to save more, why your risk is what it is, how you compare to other students, about debt/credit basics, or how to build an emergency fund — I'll go into detail on any of it.`;
}

/* ---------------- progress ---------------- */
function renderProgress(){
  const analyses = getAnalyses();
  const empty = document.getElementById('progress-empty');
  const content = document.getElementById('progress-content');
  if(analyses.length === 0){ empty.style.display = 'block'; content.style.display = 'none'; return; }
  empty.style.display = 'none';
  content.style.display = 'block';

  const ctx = document.getElementById('chart-progress').getContext('2d');
  destroyChart('chart-progress');
  charts['chart-progress'] = new Chart(ctx, {
    type: 'line',
    data: {
      labels: analyses.map((a,i) => `#${i+1} · ${a.date}`),
      datasets: [
        { label: 'Total spending', data: analyses.map(a => a.totalSpending), borderColor: '#ff6b6b', backgroundColor: 'transparent', tension:.3 },
        { label: 'Savings', data: analyses.map(a => a.savings), borderColor: '#2fe6ad', backgroundColor: 'transparent', tension:.3 }
      ]
    },
    options: {
      plugins: { legend: { labels: { color: '#9aa6c4', font:{family:'Inter'} } } },
      scales: {
        x: { ticks: { color: '#5f6b8c', font:{family:'IBM Plex Mono', size:10} }, grid: { color:'#1c2842' } },
        y: { ticks: { color: '#5f6b8c', font:{family:'IBM Plex Mono', size:10} }, grid: { color:'#1c2842' } }
      }
    }
  });

  const rows = document.getElementById('history-rows');
  rows.innerHTML = '';
  analyses.slice().reverse().forEach((a, idx) => {
    const badgeClass = a.risk === 'Low Spending Risk' ? 'low' : (a.risk === 'Balanced Spending' ? 'balanced' : 'high');
    const row = document.createElement('div');
    row.className = 'history-row';
    row.innerHTML = `
      <div><div>Analysis #${analyses.length - idx}</div><div class="date">${a.date}</div></div>
      <div style="font-family:var(--mono); font-size:13px;">${fmt(a.totalSpending)} spent · ${fmt(a.savings)} saved</div>
      <div class="risk-badge ${badgeClass}"><span class="dot"></span>${a.risk}</div>
    `;
    rows.appendChild(row);
  });
}

