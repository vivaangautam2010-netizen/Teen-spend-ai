    ]},
    {title:'Week 2 · Cut the easy fat', items:[
      advice.topCat.isOver ? `Set a weekly cap of about ${fmt(Math.round(advice.topCat.newAmt/4))} for ${topLabel}.` : `Cancel or pause one subscription/purchase you listed in Week 1 that you rarely use.`,
      `Try the 24-hour rule before any non-essential purchase over $20.`
    ]},
    {title:'Week 3 · Build the habit', items:[
      `Automate moving a set amount to savings as soon as income arrives, aiming for a ${Math.max(10, Math.round(advice.savingsRate)+5)}% savings rate.`,
      `Re-check your ${topLabel} spend against your Week 1 baseline.`
    ]},
    {title:'Week 4 · Review & lock in', items:[
      `Re-run your SpendSense AI analysis and compare your new risk category to today's.`,
      `Keep whichever of these changes actually stuck, and drop the ones that didn't fit your routine.`
    ]}
  ];
  planEl.innerHTML = weeks.map(w => `
    <div class="week-card">
      <h4>${w.title}</h4>
      <ul>${w.items.map(it => `<li>${it}</li>`).join('')}</ul>
    </div>
  `).join('');

  const projEl = document.getElementById('advice-projection');
  projEl.innerHTML = `
    <div class="stat-card"><div class="label">Potential monthly savings</div><div class="value green">${fmt(Math.round(advice.monthlyDelta))}</div></div>
    <div class="stat-card"><div class="label">Potential annual impact</div><div class="value green">${fmt(Math.round(advice.annualDelta))}</div></div>
    <div class="stat-card"><div class="label">Current savings rate</div><div class="value">${Math.round(advice.savingsRate)}%</div></div>
    <div class="stat-card"><div class="label">Projected savings rate</div><div class="value green">${Math.round(advice.newSavingsRate)}%</div></div>
  `;
}


