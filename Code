/* ---------------- real AI chat (Claude), with offline fallback ----------------
   The chatbot's primary path calls the Claude API directly so it can
   genuinely answer any finance-related question, not just the fixed
   set of keyword patterns below. chatApiHistory carries real
   conversation memory between turns (so follow-up questions work)
   even though the UI only ever shows the latest exchange.
   If the API call fails — e.g. this file has been exported and is
   running on a plain static host with no key/proxy behind it — it
   falls back to the original rule-based generateChatReply() further
   down, so the chatbot never just goes silent. */
const AI_MODEL = "claude-sonnet-4-6";
let chatApiHistory = [];

function buildSystemPrompt(){
  const user = getUser();
  const latest = getLatestAnalysis();
  let ctx = `You are the AI assistant built into SpendSense AI, a spending-habit app for teenagers. `
    + `Speak directly to the user in a warm, encouraging, specific tone, and go into real detail — don't shy away from a fuller explanation when the question calls for it. Use concrete numbers when you have them, never generic filler. `
    + `You can answer ANY finance-related question in depth: spending, budgeting, saving, debt, credit, investing, taxes, income, insurance, financial terms and concepts. `
    + `You're also the go-to helper for questions about how this website/app itself works (its tabs, the AI Advice plan, the benchmark comparison, the calculator, accounts, the theme toggle, quick access). `
    + `Beyond that, you're also happy to help with reasonable general questions outside finance — treat them like any capable, knowledgeable assistant would, giving a genuinely useful, detailed answer rather than refusing. `
    + `Only decline something if it's actually harmful, unsafe, inappropriate, or so unrelated/nonsensical that there's genuinely nothing useful to say — not simply because it's unrelated to money. When you do decline, say it plainly and briefly, e.g. "I can't answer this — it's irrelevant and not related to what I can help with here," rather than a long justification. `
    + `Data you can reference if relevant:\n`;
  if(user) ctx += `- User's first name: ${user.name.split(' ')[0]}\n`;
  if(latest){
    ctx += `- Latest spending analysis: risk category "${latest.risk}", monthly income ${fmt(latest.income)}, total spending ${fmt(latest.totalSpending)}, savings ${fmt(latest.savings)}.\n`;
    ctx += `- Category breakdown: ` + CATS.map(c => `${c.label} ${fmt(latest.categories[c.key])}`).join(', ') + `.\n`;
  } else {
    ctx += `- The user has not run a spending analysis yet — suggest the Spending Analysis tab if it would help answer their question.\n`;
  }
  ctx += `- Peer benchmark, average % of income by category from ${BENCHMARK_SAMPLE_SIZE} real students: ` + CATS.map(c => `${c.label} ${BENCHMARK_PCT_INCOME[c.key]}%`).join(', ') + `.\n`;
  ctx += `- General adult finance reference from ${FINANCE_REF.sampleSize.toLocaleString()} real records: median expense ratio ${Math.round(FINANCE_REF.expenseRatio.median*100)}% of income, median months of income saved ${FINANCE_REF.monthsSaved.median}, ${FINANCE_REF.pctNoLoan}% carry no active loan, median credit score ${FINANCE_REF.creditScore.median} (300–850 scale).\n\n`
    + `Give a full, detailed, well-explained answer — a paragraph or more if the question warrants it.`;
  return ctx;
}

async function getAIReply(userText){
  chatApiHistory.push({role: 'user', content: userText});
  if(chatApiHistory.length > 12) chatApiHistory = chatApiHistory.slice(-12);
  try{
    const response = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: {"Content-Type": "application/json"},
      body: JSON.stringify({
        model: AI_MODEL,
        max_tokens: 500,
        system: buildSystemPrompt(),
        messages: chatApiHistory
      })
    });
    const data = await response.json();
    const text = (data.content || []).map(b => b.text || '').join('\n').trim();
    if(!text) throw new Error('empty AI response');
    chatApiHistory.push({role: 'assistant', content: text});
    return text;
  } catch(err){
    chatApiHistory.pop(); // don't keep a dangling user turn with no matching reply
    return generateChatReply(userText); // offline fallback, see below
  }
}

function escapeHtml(str){
  return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

function showChatAnswer(question, answer){
  const el = document.getElementById('chat-answer');
  el.innerHTML = (question ? `<div class="chat-answer-q">You asked</div><p style="color:var(--ink-dim); font-size:14px; margin-bottom:16px;">${escapeHtml(question)}</p>` : '')
    + `<p class="chat-answer-text">${escapeHtml(answer).replace(/\n/g,'<br>')}</p>`;
}

async function sendSuggested(text){
  showChatAnswer(text, 'Thinking…');
  const reply = await getAIReply(text);
  showChatAnswer(text, reply);
}

async function handleChatSubmit(e){
  if(e && e.preventDefault) e.preventDefault();
  const input = document.getElementById('chat-input');
  const text = input.value.trim();
  if(!text) return false;
  input.value = '';
  showChatAnswer(text, 'Thinking…');
  const reply = await getAIReply(text);
  showChatAnswer(text, reply);
  return false;
}

/* Keywords that mark a question as being within the assistant's scope
   (spending, saving, budgeting, debt, credit, and the app itself).
   Anything that matches none of these gets a polite decline instead
